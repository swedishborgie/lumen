# Lumen environment configuration
# Copy this file to /etc/lumen/<username>.env and edit as needed.
# User-specific overrides can also be placed in ~/.config/lumen/env.
# Values in ~/.config/lumen/env take precedence over /etc/lumen/<username>.env.
#
# After editing, restart the service:
#   systemctl restart lumen@<username>

# ── Network ──────────────────────────────────────────────────────────────────

# Address and port for the HTTP/WebSocket server.
# Default: 0.0.0.0:8080
#LUMEN_BIND=0.0.0.0:8080

# ── Video ─────────────────────────────────────────────────────────────────────

# Virtual display resolution (pixels).
# Default: 1920 x 1080
#LUMEN_WIDTH=1920
#LUMEN_HEIGHT=1080

# Target frame rate.
# Default: 30
#LUMEN_FPS=30

# H.264 encoding bitrate in kbps.
# Default: 4000
#LUMEN_VIDEO_BITRATE_KBPS=4000

# Maximum bitrate cap in kbps (defaults to 2× LUMEN_VIDEO_BITRATE_KBPS).
#LUMEN_MAX_BITRATE_KBPS=8000

# GPU render node for VA-API hardware encoding.
# Auto-detected when unset. Set explicitly if detection fails.
# Example: /dev/dri/renderD128
#LUMEN_DRI_NODE=

# ── Audio ─────────────────────────────────────────────────────────────────────

# Opus audio bitrate in bps.
# Default: 128000
#LUMEN_AUDIO_BITRATE_BPS=128000

# PulseAudio monitor source name.
# Auto-detected (uses the default sink monitor) when unset.
# List available sources with: pactl list sources short
#LUMEN_AUDIO_DEVICE=

# ── WebRTC / ICE ──────────────────────────────────────────────────────────────

# Comma-separated list of ICE server URLs.
# Default: stun:stun.l.google.com:19302
#LUMEN_ICE_SERVERS=stun:stun.l.google.com:19302

# ── TURN Server ───────────────────────────────────────────────────────────────

# UDP port for the embedded TURN server. Set to 0 to disable TURN.
# Default: 3478
#LUMEN_TURN_PORT=3478

# External IP advertised by the TURN server.
# Auto-detected via UDP routing probe when unset.
#LUMEN_TURN_EXTERNAL_IP=

# TURN credentials.
# When not set, lumen auto-generates a random ephemeral credential pair at
# startup. The generated credentials are sent to the browser via /api/config
# and are valid only for the lifetime of the process.
# Set these explicitly only if you need stable credentials (e.g. for an
# external TURN server that lumen does not manage).
#LUMEN_TURN_USERNAME=
#LUMEN_TURN_PASSWORD=

# UDP relay port range for TURN.
# Default: 50000–50010
#LUMEN_TURN_MIN_PORT=50000
#LUMEN_TURN_MAX_PORT=50010

# ── Authentication ────────────────────────────────────────────────────────────

# Authentication mode. One of: none, basic, bearer, oauth2
# Default: basic
#LUMEN_AUTH=basic

# --- Bearer token auth (LUMEN_AUTH=bearer) ---
# A secret token clients must supply as: Authorization: Bearer <token>
#LUMEN_AUTH_BEARER_TOKEN=

# --- HTTP Basic auth (LUMEN_AUTH=basic) ---
# Uses system PAM. Username must match the user running lumen.
# No extra variables needed.

# --- OAuth2 / OpenID Connect (LUMEN_AUTH=oauth2) ---
# All five variables below are required when LUMEN_AUTH=oauth2.
#LUMEN_AUTH_OAUTH2_ISSUER_URL=https://auth.example.com
#LUMEN_AUTH_OAUTH2_CLIENT_ID=
#LUMEN_AUTH_OAUTH2_CLIENT_SECRET=
#LUMEN_AUTH_OAUTH2_REDIRECT_URI=https://lumen.example.com/auth/callback
# The `sub` claim from the ID token that is allowed access.
#LUMEN_AUTH_OAUTH2_SUBJECT=

# ── TLS / HTTPS ───────────────────────────────────────────────────────────────

# PEM certificate chain and private key for HTTPS/WSS.
# When unset, lumen serves plain HTTP. Both must be set together.
#LUMEN_TLS_CERT=/etc/lumen/cert.pem
#LUMEN_TLS_KEY=/etc/lumen/key.pem

# ── Web Assets ────────────────────────────────────────────────────────────────

# Path to the browser client files directory.
# Default: /usr/share/lumen/web  (set by the service unit)
#LUMEN_STATIC_DIR=/usr/share/lumen/web

# ── Desktop Environment ───────────────────────────────────────────────────────

# Named desktop environment preset to launch once the compositor is ready.
# Accepted values:
#   labwc  — lightweight wlroots compositor (default; labwc and foot must be installed)
#   kde    — KDE Plasma session via dbus-run-session startplasma-wayland
#            (KDE packages must be installed separately)
LUMEN_DESKTOP=labwc

# For KDE Plasma, set:
#LUMEN_DESKTOP=kde

# Advanced: override the launch command entirely (ignores the preset command
# but still applies its environment variables when --desktop is also set).
# Use this for custom compositors, nested Wayland desktops, or testing.
#LUMEN_LAUNCH=labwc

# ── Logging ───────────────────────────────────────────────────────────────────

# Tracing filter for log output (journalctl -u lumen@<username>).
# Format: crate=level,crate=level  Levels: error, warn, info, debug, trace
# Default when unset: info for all lumen crates
#RUST_LOG=lumen=info
